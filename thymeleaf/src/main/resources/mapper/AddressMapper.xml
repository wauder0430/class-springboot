<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
    
<!-- src/main/resources > mappers > address.xml -->
<mapper namespace="com.test.java.mapper.AddressMapper">
	
	<select id="count" resultType="int">
	   select count(*) from tblAddress
	</select>
	
	<select id="get" parameterType="int" resultType="com.test.java.model.AddressDto">
	   select * from tblAddress where seq = #{_parameter}
	</select>
    
    <select id="names" resultType="String">
        select name from tblAddress
    </select>
    
    <select id="list" resultType="AddressDto">
        select * from tblAddress
    </select>
	
</mapper>
